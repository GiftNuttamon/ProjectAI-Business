    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\n\nconst orders   = $('Fetch Orders').all().map(r => r.json);\nconst payments = $('Fetch Payments').all().map(r => r.json);\n\nconst todayOrders   = orders.filter(r   => (r.timestamp || '').startsWith(today));\nconst todayPayments = payments.filter(r => (r.timestamp || '').startsWith(today));\n\nconst totalRevenue = todayPayments\n  .filter(r => r.is_duplicate !== 'true' && r.is_duplicate !== true)\n  .reduce((sum, r) => sum + (parseFloat(r.payment_amount) || 0), 0);\n\nconst orderCount     = todayOrders.length;\nconst paidCount      = todayPayments.length;\nconst duplicateCount = todayPayments.filter(r => r.is_duplicate === 'true' || r.is_duplicate === true).length;\nconst pendingList    = todayOrders.filter(r => (r.auto_tags || '').includes('Pending_Payment'));\nconst highPriority   = todayOrders.filter(r => (r.auto_tags || '').includes('High_Priority')).length;\n\nconst productCount = {};\ntodayOrders.forEach(r => {\n  if (r.product_name) productCount[r.product_name] = (productCount[r.product_name] || 0) + 1;\n});\nconst topProducts = Object.entries(productCount)\n  .sort((a, b) => b[1] - a[1]).slice(0, 3)\n  .map(([name, count]) => '• ' + name + ' (' + count + ' ออเดอร์)').join('\\n') || 'ไม่มีข้อมูล';\n\nconst pendingNames = pendingList\n  .map(r => '• ' + (r.recipient_name || r.userId)).join('\\n') || 'ไม่มี';\n\nconst message = '📊 ChatBuddy รายงานประจำวัน\\n'\n  + '📅 ' + today + '\\n'\n  + '━━━━━━━━━━━━━━━\\n'\n  + '💰 ยอดขายรวม: ' + totalRevenue.toLocaleString() + ' บาท\\n'\n  + '📦 ออเดอร์: ' + orderCount + ' รายการ\\n'\n  + '✅ ชำระแล้ว: ' + paidCount + ' รายการ\\n'\n  + '⚠️ สลิปซ้ำ: ' + duplicateCount + ' รายการ\\n'\n  + '⏳ รอชำระ: ' + pendingList.length + ' รายการ\\n'\n  + '🚨 High Priority: ' + highPriority + ' เคส\\n'\n  + '━━━━━━━━━━━━━━━\\n'\n  + '🏆 สินค้าขายดีวันนี้:\\n' + topProducts + '\\n'\n  + '━━━━━━━━━━━━━━━\\n'\n  + '⚠️ ลูกค้ารอชำระ:\\n' + pendingNames;\n\nreturn [{ json: { message } }];"
      },
