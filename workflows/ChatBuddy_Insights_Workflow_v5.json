      "id": "n5",
      "name": "Thunder: Verify Slip",
      "type": "n8n-nodes-thunder.thunder",
      "typeVersion": 1,
      "position": [
        1120,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const slipData = $input.first().json;\nconst prev = $('Pre-process Payload').first().json;\n\nconst isDuplicate = slipData.message === 'duplicate_slip';\nconst data = slipData.data || {};\nconst amount           = data.amount || 0;\nconst receiverName     = (data.receiver && data.receiver.account && data.receiver.account.name) ? (data.receiver.account.name.th || data.receiver.account.name.en || 'ไม่ระบุ') : 'ไม่ระบุ';\nconst receiverBankId   = (data.receiver && data.receiver.bank) ? (data.receiver.bank.id   || 'ไม่ระบุ') : 'ไม่ระบุ';\nconst receiverBankName = (data.receiver && data.receiver.bank) ? (data.receiver.bank.name || 'ไม่ระบุ') : 'ไม่ระบุ';\nconst senderName       = (data.sender   && data.sender.account && data.sender.account.name) ? (data.sender.account.name.th || data.sender.account.name.en || 'ไม่ระบุ') : 'ไม่ระบุ';\nconst txDate           = data.transactionDate || prev.timestamp;\nconst reference        = data.reference || '';\n\nreturn [{\n  json: {\n    ...prev,\n    intent: 'Payment_Proof',\n    sentiment: 'Positive',\n    summary: 'สลิปโอนเงิน ' + amount + ' บาท จาก ' + senderName,\n    entities: {\n      payment_amount: amount,\n      sender_name: senderName,\n      receiver_name: receiverName,\n      receiver_bank_id: receiverBankId,\n      receiver_bank_name: receiverBankName,\n      transaction_date: txDate,\n      reference: reference\n    },\n    auto_tags: isDuplicate ? '#Slip_Duplicate,#Paid_รอส่ง' : '#Paid_รอส่ง',\n    slipValid: true,\n    isDuplicate: isDuplicate\n  }\n}];"
      },
      "id": "n6",
      "name": "Parse Slip Matched",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        140
      ]
