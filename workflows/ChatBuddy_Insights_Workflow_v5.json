    {
      "parameters": {
        "jsCode": "const prev = $('Pre-process Payload').first().json;\nconst replyToken = prev.replyToken;\nconst allOrders = $input.all().map(r => r.json);\n\n// Get search_query from agent parsed output\nconst agentData = $('Parse Agent Response').first().json;\nconst searchQuery = (agentData.entities && agentData.entities.search_query\n  ? agentData.entities.search_query : '').toLowerCase().trim();\n\nif (!searchQuery) {\n  return [{ json: {\n    replyToken,\n    reply_message: 'กรุณาแจ้งชื่อผู้รับ หรือเบอร์โทรที่ใช้สั่งสินค้าด้วยนะคะ 🙏'\n  }}];\n}\n\n// Search by recipient_name or phone_number (partial, case-insensitive)\nconst matched = allOrders.filter(r => {\n  const name  = (r.recipient_name || '').toLowerCase();\n  const phone = (r.phone_number   || '').toLowerCase();\n  return name.includes(searchQuery) || phone.includes(searchQuery);\n}).sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));\n\nif (!matched.length) {\n  return [{ json: {\n    replyToken,\n    reply_message: 'ขออภัยค่ะ ไม่พบออเดอร์ของ \"' + searchQuery + '\" ในระบบ\\n'\n      + 'กรุณาตรวจสอบชื่อหรือเบอร์โทรอีกครั้ง หรือติดต่อแอดมินได้เลยนะคะ 🙏'\n  }}];\n}\n\nconst statusEmoji = {\n  Pending_Payment: '⏳',\n  Paid: '💳',\n  Shipped: '🚚',\n  Delivered: '✅'\n};\n\nlet msg = '📦 สถานะออเดอร์ทั้งหมด (' + matched.length + ' รายการ)\\n';\nmsg += '━━━━━━━━━━━━━━━\\n';\n\nmatched.forEach((o, i) => {\n  const emoji = statusEmoji[o.status] || '📋';\n  const date  = o.timestamp ? o.timestamp.split('T')[0] : '-';\n  msg += (i + 1) + '. ' + (o.product_name || '-') + ' x' + (o.quantity || '1') + '\\n';\n  msg += '   ' + emoji + ' สถานะ: ' + (o.status || '-') + '\\n';\n  if (o.tracking_number) msg += '   🔍 Tracking: ' + o.tracking_number + '\\n';\n  if (o.status === 'Pending_Payment') {\n    msg += '   💰 ยอดที่ต้องชำระ: ' + (o.payment_amount || 'กรุณาสอบถาม') + ' บาท\\n';\n  }\n  msg += '   📅 วันที่สั่ง: ' + date + '\\n';\n  if (i < matched.length - 1) msg += '───────────\\n';\n});\n\nmsg += '━━━━━━━━━━━━━━━\\n';\nmsg += 'มีข้อสงสัยเพิ่มเติมสอบถามได้เลยนะคะ 😊';\n\nreturn [{ json: { replyToken, reply_message: msg } }];"
      },
