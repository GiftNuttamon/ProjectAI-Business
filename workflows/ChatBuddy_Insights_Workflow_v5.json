    {
      "parameters": {
        "jsCode": "const prev = $('Pre-process Payload').first().json;\nreturn [{\n  json: {\n    ...prev,\n    intent: 'Payment_Proof',\n    sentiment: 'Neutral',\n    summary: 'สลิปไม่ตรงกับเงื่อนไขที่ตั้งไว้',\n    entities: {},\n    auto_tags: '#Slip_Not_Matched',\n    slipValid: false,\n    isDuplicate: false\n  }\n}];"
      },
