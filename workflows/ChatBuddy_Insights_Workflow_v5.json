      "id": "n13",
      "name": "Tool get product info",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 1.2,
      "position": [
        1040,
        740
      ]
    },
    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json.output || $input.first().json.text || '';\nconst prev = $('Pre-process Payload').first().json;\n\nlet parsed;\ntry {\n  const cleaned = agentOutput.replace(/```json/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    intent: 'Other',\n    sentiment: 'Neutral',\n    summary: 'วิเคราะห์ไม่ได้',\n    reply_message: 'ขอโทษค่ะ ระบบขัดข้องชั่วคราว กรุณาลองใหม่อีกครั้งนะคะ 🙏',\n    entities: {},\n    auto_tags: []\n  };\n}\n\nreturn [{\n  json: {\n    ...prev,\n    intent:        parsed.intent        || 'Other',\n    sentiment:     parsed.sentiment     || 'Neutral',\n    summary:       parsed.summary       || '',\n    reply_message: parsed.reply_message || '',\n    entities:      parsed.entities      || {},\n    auto_tags:     Array.isArray(parsed.auto_tags) ? parsed.auto_tags.join(',') : '',\n    analyzedAt:    new Date().toISOString()\n  }\n}];"
      },
